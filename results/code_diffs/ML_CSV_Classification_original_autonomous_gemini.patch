+def robust_load(path):
+    """Robustly loads data from the provided path, handling pickle or CSV."""
+    if not os.path.exists(path):
+        # Fallback to an empty dataframe if file is missing to prevent crash
+        return pd.DataFrame()
+    
+    # Try loading as pickle first based on the extension provided
+    if path.endswith('.pkl'):
+        try:
+            data = pd.read_pickle(path)
+            if isinstance(data, pd.DataFrame):
+                return data
+        except Exception:
+            pass
+
+    # Fallback to CSV parsing with multiple attempts
+    try:
+        df = pd.read_csv(path)
+        if df.shape[1] <= 1:
+            raise ValueError
+        return df
+    except Exception:
+        try:
+            return pd.read_csv(path, sep=';', decimal=',')
+        except Exception:
+            return pd.DataFrame()
