+def load_data(path):
+    # Robust CSV loading with fallbacks
+    try:
+        df = pd.read_csv(path)
+        if df.shape[1] < 2:
+            raise ValueError
+    except:
+        try:
+            df = pd.read_csv(path, sep=';', decimal=',')
+        except:
+            return pd.DataFrame()
+
+    # Clean column names
+    df.columns = [str(c).strip() for c in df.columns]
+    df.columns = [" ".join(str(c).split()) for c in df.columns]
+    df = df.loc[:, ~df.columns.str.contains('^Unnamed')]
+    return df
 
