+def minmax_scale_trainstyle(X: pd.DataFrame) -> pd.DataFrame:
+    X_min = X.min(axis=0)
+    X_max = X.max(axis=0)
+    denom = X_max - X_min
+    denom = denom.replace(0, 1)
+    return (X - X_min) / denom
+
